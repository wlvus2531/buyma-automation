{
  "manifest_version": 3,
  "name": "BUYMA 모니터링",
  "version": "1.0.0",
  "description": "바이마 경쟁자 가격·순위 실시간 수집 — buyma-automation 시스템 연동",
  "permissions": ["storage", "notifications", "alarms"],
  "host_permissions": [
    "https://www.buyma.com/*",
    "https://buyma-automation-vi3y.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.buyma.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BUYMA 모니터링"
  }
}
